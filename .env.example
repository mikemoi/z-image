# 服务器部署配置。复制为 .env 后务必改掉下面三个密钥/口令。
# docker compose 会读取本文件。

# 数据库密码(compose 里的 db 服务和 DATABASE_URL 都用它)
POSTGRES_PASSWORD=change-me-strong-password

# 单用户鉴权 token,前端请求头 Authorization: Bearer <此值>
AUTH_TOKEN=change-me-random-token

# OpenRouter(Vision)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
VISION_MODEL=openai/gpt-4.1-mini
VISION_DAILY_BUDGET=500

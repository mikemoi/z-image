# 复制为 .env 后按需修改。.env 不入库。

# PostgreSQL 连接串
DATABASE_URL=postgresql://postgres:zbrain2024@localhost:5432/zbrain

# 单用户鉴权 token,前端请求头 Authorization: Bearer <此值>
AUTH_TOKEN=dev-token-change-me

# 原图磁盘根目录
FILES_ROOT=./data/zbrain/files

# OpenRouter(第三步 Vision 用)
OPENROUTER_API_KEY=
VISION_MODEL=openai/gpt-4.1-mini
# INSIGHT_MODEL=openai/gpt-4.1
# 自动分类默认沿用 VISION_MODEL，三种模型均可在「AI 设置」中覆盖并即时生效。
VISION_DAILY_BUDGET=0
VISION_MAX_ATTEMPTS=3
WORKER_POLL_SECONDS=8
